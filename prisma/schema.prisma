generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         Role       @default(ANALYST)
  createdAt    DateTime   @default(now())
  assets       Asset[]
  auditLogs    AuditLog[]
}

model Asset {
  id           String        @id @default(cuid())
  url          String
  name         String
  addedById    String
  createdAt    DateTime      @default(now())
  scanEnabled  Boolean       @default(true)
  alerts       Alert[]
  addedBy      User          @relation(fields: [addedById], references: [id])
  snapshots    Snapshot[]
  vulnFindings VulnFinding[]

  @@index([addedById])
}

model VulnFinding {
  id        String   @id @default(cuid())
  assetId   String
  category  String
  finding   String
  severity  String
  checkedAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id])

  @@index([assetId, checkedAt])
}

model Snapshot {
  id                  String   @id @default(cuid())
  assetId             String
  contentHash         String
  rawContentSanitized String
  capturedAt          DateTime @default(now())
  screenshotPath      String?
  alerts              Alert[]
  asset               Asset    @relation(fields: [assetId], references: [id])

  @@index([assetId, capturedAt])
}

model Alert {
  id                String      @id @default(cuid())
  assetId           String
  snapshotId        String
  diffSummary       String
  aiRiskScore       Int
  aiExplanation     String
  severity          String
  status            AlertStatus @default(OPEN)
  createdAt         DateTime    @default(now())
  recommendedAction String      @default("Not assessed — generated before this field existed")
  asset             Asset       @relation(fields: [assetId], references: [id])
  snapshot          Snapshot    @relation(fields: [snapshotId], references: [id])

  @@index([assetId, status])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String
  resourceType String
  resourceId   String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

enum Role {
  ADMIN
  ANALYST
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}
